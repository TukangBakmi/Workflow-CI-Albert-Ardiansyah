name: Telco_Churn_MLProject

conda_env: conda.yaml

entry_points:
  main:
    parameters:
      data_path:
        type: str
        default: "telcocustomerchurn_preprocessing.csv"
      n_estimators:
        type: int
        default: 100
      max_depth:
        type: int
        default: 0
      model_name:
        type: str
        default: "telco-churn-model"
    command: >-
      python modelling.py
      --data_path {data_path}
      --n_estimators {n_estimators}
      --max_depth {max_depth}
      --model_name {model_name}